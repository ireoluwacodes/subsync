# SubSync environment configuration
# Copy to .env and adjust as needed

APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=debug

# Public API base URL (used for computed Nomba inbound webhook URLs)
PUBLIC_BASE_URL=http://localhost:8080

# Local PostgreSQL (preferred — individual vars)
DB_HOST=localhost
DB_PORT=5432
DB_USER=cierge_user
DB_PASSWORD=cierge_pass
DB_NAME=subsync

# Or set a full connection string (overrides DB_* above)
# POSTGRES_DSN=postgres://cierge_user:cierge_pass@localhost:5432/subsync?sslmode=disable

# Redis (docker compose: make up)
REDIS_URL=redis://localhost:6379/0

# Encrypt per-tenant Nomba client secrets at rest (32-byte key, base64 or hex)
NOMBA_CREDENTIALS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Merchant dashboard JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h

# Mock invoice charge result in Phase 2 (success|failure)
BILLING_MOCK_RESULT=success

# Optional dev fallback for inbound Nomba webhook verification
NOMBA_WEBHOOK_SIGNING_KEY=

# Bootstrap secret for POST /v1/tenants (required in production)
BOOTSTRAP_SECRET=change-me-in-production

# Outbound SubSync → merchant webhook signing (per-tenant secret generated at tenant creation)
WEBHOOK_SIGNING_SECRET=
