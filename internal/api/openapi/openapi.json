          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/invoices/{id}/pdf": {
      "get": {
        "summary": "Download invoice PDF",
        "tags": ["Invoices"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": {
            "description": "Invoice PDF bytes",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/invoices/{id}/void": {
      "post": {
        "summary": "Void open invoice",
        "tags": ["Invoices"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/invoices/{id}/retry": {
      "post": {
        "summary": "Retry failed invoice charge",
        "tags": ["Invoices"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/webhook-endpoints": {
      "get": {
        "summary": "List outbound webhook endpoints",
        "tags": ["Webhooks"],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "summary": "Create webhook endpoint",
        "tags": ["Webhooks"],
        "responses": {
          "201": { "$ref": "#/components/responses/Created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/webhook-endpoints/{id}": {
      "get": {
        "summary": "Get webhook endpoint",
        "tags": ["Webhooks"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update webhook endpoint",
        "tags": ["Webhooks"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete webhook endpoint",
        "tags": ["Webhooks"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/webhook-endpoints/{id}/deliveries": {
      "get": {
        "summary": "List webhook delivery attempts",
        "tags": ["Webhooks"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/portal/token": {
      "post": {
        "summary": "Issue customer portal link token",
        "tags": ["Portal"],
        "responses": {
          "201": { "$ref": "#/components/responses/Created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "tags": [
    { "name": "Plans", "description": "Subscription plan catalog" },
    { "name": "Customers", "description": "End-customer records" },
    { "name": "Payment Methods", "description": "Tokenized Nomba cards" },
    { "name": "Subscriptions", "description": "Billing subscriptions and checkout" },
    { "name": "Invoices", "description": "Billing invoices" },
    { "name": "Webhooks", "description": "Outbound event delivery configuration" },
    { "name": "Portal", "description": "Customer self-service links" }
  ],
  "components": {
    "parameters": {
      "ResourceID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "description": "Resource UUID"
      }
    },
    "responses": {
      "Ok": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      },
      "Created": {
        "description": "Created",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      },
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      },
      "Conflict": {
        "description": "Conflict with current state",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Envelope" }
          }
        }
      }
    },
    "schemas": {
      "MoneyMinorAmount": {
        "type": "integer",
        "format": "int64",
        "description": "Amount in the currency's minor unit (kobo for NGN). Example: 100000 = ₦1,000.00.",
        "example": 100000
      },
      "MoneyDisplay": {
        "type": "string",
        "description": "Human-readable major-unit string for UI display, computed from the paired minor-unit field.",
        "example": "₦1000"
      },
      "CurrencyCode": {
        "type": "string",
        "description": "ISO 4217 currency code.",
        "example": "NGN"
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "amount": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "amount_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "currency": { "$ref": "#/components/schemas/CurrencyCode" },
          "name": { "type": "string" },
          "interval": { "type": "string", "enum": ["monthly", "annual", "custom"] }
        }
      },
      "CreatePlanRequest": {
        "type": "object",
        "required": ["name", "amount", "interval"],
        "properties": {
          "name": { "type": "string" },
          "amount": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "currency": { "$ref": "#/components/schemas/CurrencyCode" },
          "interval": { "type": "string", "enum": ["monthly", "annual", "custom"] },
          "trial_days": { "type": "integer" }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "amount_due": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "amount_due_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "amount_paid": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "amount_paid_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "currency": { "$ref": "#/components/schemas/CurrencyCode" },
          "status": { "type": "string" }
        }
      },
      "PlanStats": {
        "type": "object",
        "properties": {
          "active_subscribers": { "type": "integer" },
          "mrr_estimate": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "mrr_estimate_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "currency": { "$ref": "#/components/schemas/CurrencyCode" }
        }
      },
      "ProrationPreview": {
        "type": "object",
        "properties": {
          "credit_amount": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "credit_amount_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "debit_amount": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "debit_amount_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "net_amount": { "$ref": "#/components/schemas/MoneyMinorAmount" },
          "net_amount_display": { "$ref": "#/components/schemas/MoneyDisplay" },
          "currency": { "$ref": "#/components/schemas/CurrencyCode" },
          "days_remaining": { "type": "integer" },
          "total_days": { "type": "integer" }
        }
      },
      "Envelope": {
        "type": "object",
        "properties": {
          "data": {},
          "meta": {
            "type": "object",
            "properties": {
              "request_id": { "type": "string" },
              "page": { "type": "integer" },
              "per_page": { "type": "integer" },
              "total": { "type": "integer" }
            }
          },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Merchant API key prefixed with `ssk_`. Send as `Authorization: Bearer ssk_...`."
      }
    }
  },
  "security": [{ "apiKeyAuth": [] }]
}
