{
  "openapi": "3.0.3",
  "info": {
    "title": "SubSync Integrator API",
    "version": "1.0.0",
    "description": "Server-to-server API for Nomba-powered merchants. Authenticate with `Authorization: Bearer ssk_...` on all routes below. Dashboard-only routes (auth, settings, analytics, /me) are not listed here.\n\n## Money\n\nAll monetary integer fields (`amount`, `amount_due`, `amount_paid`, `mrr`, `mrr_estimate`, proration amounts, etc.) are in the currency's **minor unit** (kobo for `NGN`). Divide by 100 for major units. Example: `100000` with `NGN` is ₦1,000.00.\n\nResponses may include paired `*_display` strings (e.g. `amount_display`) formatted for UI. Use minor-unit integers for billing logic; use `*_display` for presentation only."
  },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/plans": {
      "get": {
        "summary": "List plans",
        "tags": ["Plans"],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "summary": "Create plan",
        "tags": ["Plans"],
        "responses": {
          "201": { "$ref": "#/components/responses/Created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/plans/{id}": {
      "get": {
        "summary": "Get plan",
        "tags": ["Plans"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update plan",
        "tags": ["Plans"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Archive plan",
        "tags": ["Plans"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/plans/{id}/stats": {
      "get": {
        "summary": "Active subscription count for plan",
        "tags": ["Plans"],
        "parameters": [{ "$ref": "#/components/parameters/ResourceID" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
